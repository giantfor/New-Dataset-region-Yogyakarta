Map.addLayer(
  predictedPoints.style({
    color: '#000000',
    pointSize: 1,
    pointShape: 'circle',
    width: 1
  }),
  {},
  'Predicted landslide points',
  true
);

// =====================================
// 19. LEGEND (ENGLISH)
// =====================================
var legend = ui.Panel({
  style: {
    position: 'bottom-right',
    padding: '10px 12px',
    backgroundColor: 'rgba(255,255,255,0.92)',
    width: '220px'
  }
});

legend.add(ui.Label({
  value: 'Map Legend',
  style: {
    fontWeight: 'bold',
    fontSize: '13px',
    margin: '0 0 8px 0',
    color: '#111111'
  }
}));

function legendRow(color, label, type) {
  var symbol;
  if (type === 'line') {
    symbol = ui.Label({
      value: '━━',
      style: {
        color: color,
        fontSize: '13px',
        margin: '0 8px 4px 0'
      }
    });
  } else if (type === 'triangle') {
    symbol = ui.Label({
      value: '▲',
      style: {
        color: color,
        fontSize: '14px',
        margin: '0 8px 4px 0'
      }
    });
  } else {
    symbol = ui.Label({
      style: {
        backgroundColor: color,
        padding: '6px',
        margin: '0 8px 4px 0'
      }
    });
  }

  var txt = ui.Label({
    value: label,
    style: {
      fontSize: '11px',
      margin: '0 0 4px 0'
    }
  });

  legend.add(ui.Panel([symbol, txt], ui.Panel.Layout.Flow('horizontal')));
}

legendRow('#ff0000', 'DIY boundary', 'line');
legendRow('#FFD700', 'Major rivers', 'line');
legendRow('#8B4513', 'Mountain', 'triangle');
legendRow('#FF1A1A', 'Observed landslides', 'box');
legendRow('#000000', 'Predicted landslides', 'box');
legendRow('#000000', 'Contours', 'line');

legend.add(ui.Label({
  value: 'Elevation',
  style: {
    fontWeight: 'bold',
    fontSize: '11px',
    margin: '8px 0 4px 0'
  }
}));

var elevationPalette = [
  'd8f3dc','b7e4c7','95d5b2','74c69d','52b788',
  '40916c','2d6a4f','c2b280','a98467','7f5539','4b2e1f'
];

