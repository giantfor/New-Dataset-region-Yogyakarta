});

legend.add(colorBar);

legend.add(ui.Panel([
  ui.Label('Low', {margin: '4px 8px', fontSize: '10px'}),
  ui.Label('High', {
    margin: '4px 8px',
    fontSize: '10px',
    textAlign: 'right',
    stretch: 'horizontal'
  })
], ui.Panel.Layout.Flow('horizontal')));

Map.add(legend);

